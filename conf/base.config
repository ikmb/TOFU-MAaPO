// Process setting
process {

	shell = ['/bin/bash', '-euo', 'pipefail']

	errorStrategy = { task.attempt <= 3 ? 'retry' : 'finish' }
	maxRetries = 3
	maxErrors = -1
	container = "docker://ikmb/metagenome:1.5.1"

	resourceLimits = [
        cpus: params.max_cpus,
        memory: params.max_memory,
        time: params.max_time
    ]

	// Specific cluster parameters for each process
	withLabel: 'local_run' {
		executor = 'local'
		cpus = { 1 * task.attempt }
		memory = { 4.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}
	
	withLabel: 'local_download' {
		executor = 'local'
		errorStrategy = {
			sleep( Math.pow( 2, task.attempt ) * 200 as long )
			return 'retry'
		}
		maxRetries = 10
		maxForks = 10
		cpus = { 1 * task.attempt }
		memory = { 4.GB * task.attempt }
		container = "docker://quay.io/biocontainers/curl:7.80.0"
	}

	withLabel: 'default' {
		cpus = { 4 * task.attempt }
		memory = { 15.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'default_highmemory' {
		cpus = { 4 * task.attempt }
		memory = { 60.GB * (2**(task.attempt-1)) }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'entrez' {
		maxForks = 5
		errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
		executor = 'local'
		cpus = { 1 * task.attempt }
		memory = { 4.GB * task.attempt }
		container = "docker://quay.io/biocontainers/entrez-direct:22.4--he881be0_0"
	}

	withLabel: 'fastqc' {
		cpus = { 2 * task.attempt }
		memory = { 8.GB * task.attempt }
		container = "docker://quay.io/biocontainers/fastqc:0.11.9--hdfd78af_1"
	}

	withLabel: 'metaphlan' {
		cpus = { 8 * task.attempt }
		memory = { 20.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'bbmap' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = "docker://quay.io/biocontainers/bbmap:39.00--h5c4e2a8_0"
	}

	withLabel: 'fastp' {
		cpus = { 4 * task.attempt }
		memory = { 8.GB * task.attempt }
		container = "docker://quay.io/biocontainers/fastp:0.23.4--hadf994f_2"
	}

	withLabel: 'bowtie2qc' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'comebin' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
	}

	withLabel: 'vamb' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = "docker://eikematthias/vamb_test:5.0.4"
	}

	withLabel: 'strobealing' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = 'docker://quay.io/biocontainers/strobealign:0.16.0--h5ca1c30_0'
	}
/*
	withName: 'vamb' {
		label 'exclusive' // vamb does not control for numpy threads, which takes all threads by default
	}
*/
	withLabel: 'bowtie2' {
		cpus = { 12 * task.attempt }
		memory = { 60.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'megahit' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = "docker://quay.io/biocontainers/megahit:1.2.9--h2e03b76_1"
	}

	withLabel: 'metabat2' {
		cpus = { 12 * task.attempt }
		memory = { 30.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'semibin' {
		cpus = { 12 * task.attempt }
		memory = { 40.GB * task.attempt }
	}

	withLabel: 'checkm' {
		cpus = { 12 * task.attempt }
		memory = { 80.GB * task.attempt }
		container = "docker://quay.io/biocontainers/checkm-genome:1.1.3--py_1"
	}

	withLabel: 'gtdbtk' {
		cpus = { 12 * task.attempt }
		memory = { 100.GB * task.attempt }
		container = "docker://quay.io/biocontainers/gtdbtk:2.3.2--pyhdfd78af_0"
	}

	withLabel: 'humann' {
		cpus = { 12 * task.attempt }
		memory = { 40.GB * (2**(task.attempt-1)) }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'multiqc' {
		cpus = { 8 * task.attempt }
		memory = { 16.GB * task.attempt }
		container = "docker://quay.io/biocontainers/multiqc:1.15--pyhdfd78af_0"
	}

	withLabel: 'kraken' {
		container = "docker://quay.io/biocontainers/kraken2:2.1.2--pl5321h9f5acd7_2"
		cpus = { 8 * task.attempt }
		memory = { 60.GB * task.attempt }
	}

	withLabel: 'bracken' {
		cpus = { 4 * task.attempt }
		memory = { 15.GB * task.attempt }
		container = "docker://quay.io/biocontainers/bracken:2.8--py27hc30c61c_0"
	}

	withLabel: 'magscot' {
		cpus = { 8 * task.attempt }
		memory = { 20.GB * task.attempt }
		container = "docker://ikmb/magscot:v1.1"
	}

	withLabel: 'maxbin2' {
		errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
		cpus = { 8 * task.attempt }
		memory = { 10.GB * task.attempt }
		container = "docker://quay.io/biocontainers/maxbin2:2.2.7--h87f3376_4"
	}

	withLabel: 'concoct' {
		cpus = { 8 * task.attempt }
		memory = { 10.GB * task.attempt }
		container = "docker://ikmb/metagenome:1.5.1"
	}

	withLabel: 'salmon' {
		cpus = { 8 * task.attempt }
		memory = { 80.GB * task.attempt }
		container = "docker://quay.io/biocontainers/salmon:1.10.1--hecfa306_2"
	}

	withLabel: 'sylph_sketch' {
		cpus = { 1 * task.attempt }
		memory = { 4.GB * task.attempt }
		container = "docker://quay.io/biocontainers/sylph:0.5.1--h4ac6f70_0"
	}

	withLabel: 'sylph_profile' {
		cpus = { (params.sylph_merge ? 16 : 1) * task.attempt }
		memory = { (params.sylph_merge ? 20.GB : 15.GB) * task.attempt }
		container = "docker://quay.io/biocontainers/sylph:0.5.1--h4ac6f70_0"
	}

	// Global parameters

	cpus = { 4 * task.attempt }
	memory = { 16.GB * task.attempt }
	time = { 4.h * task.attempt }

	withLabel: 'short_run' {
		time = { 8.h * task.attempt }
	}
	withLabel: 'medium_run' {
		time = { 12.h * task.attempt }
	}
	withLabel: 'long_run' {
		time = { 24.h * task.attempt }
	}
		withLabel: 'very_long_run' {
		time = { 48.h * task.attempt }
	}
	withLabel: 'gpu' {
		time = { 24.h * task.attempt }
	}
}
